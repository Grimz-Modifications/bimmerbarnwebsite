{
  "name": "ContactInquiry",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Customer name"
    },
    "email": {
      "type": "string",
      "description": "Customer email"
    },
    "phone": {
      "type": "string",
      "description": "Customer phone"
    },
    "subject": {
      "type": "string",
      "description": "Inquiry subject"
    },
    "message": {
      "type": "string",
      "description": "Inquiry message"
    },
    "vehicle_info": {
      "type": "string",
      "description": "Vehicle year/make/model"
    },
    "status": {
      "type": "string",
      "enum": [
        "new",
        "in_progress",
        "resolved"
      ],
      "default": "new"
    }
  },
  "required": [
    "name",
    "email",
    "message"
  ]
}