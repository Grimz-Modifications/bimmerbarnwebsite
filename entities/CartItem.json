{
  "name": "CartItem",
  "type": "object",
  "properties": {
    "product_id": {
      "type": "string",
      "description": "Reference to the product"
    },
    "product_name": {
      "type": "string",
      "description": "Product name for quick display"
    },
    "price": {
      "type": "number",
      "description": "Price at time of adding"
    },
    "quantity": {
      "type": "number",
      "default": 1,
      "description": "Quantity in cart"
    },
    "image_url": {
      "type": "string",
      "description": "Product image URL"
    }
  },
  "required": [
    "product_id",
    "product_name",
    "price"
  ]
}