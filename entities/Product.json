{
  "name": "Product",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Product name"
    },
    "description": {
      "type": "string",
      "description": "Product description"
    },
    "price": {
      "type": "number",
      "description": "Price in USD"
    },
    "sale_price": {
      "type": "number",
      "description": "Sale price if on sale"
    },
    "category": {
      "type": "string",
      "enum": [
        "engine",
        "suspension",
        "exhaust",
        "intake",
        "brakes",
        "exterior",
        "interior",
        "wheels_tires",
        "lighting",
        "electronics"
      ],
      "description": "Product category"
    },
    "brand_compatibility": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Compatible car brands (BMW, Audi, VW, Porsche, Mercedes)"
    },
    "model_compatibility": {
      "type": "string",
      "description": "Compatible models e.g. E46, E90, F30, G80"
    },
    "image_url": {
      "type": "string",
      "description": "Product image URL"
    },
    "in_stock": {
      "type": "boolean",
      "default": true,
      "description": "Whether the product is in stock"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether featured on homepage"
    },
    "part_number": {
      "type": "string",
      "description": "Part number / SKU"
    },
    "manufacturer": {
      "type": "string",
      "description": "Manufacturer brand name"
    }
  },
  "required": [
    "name",
    "price",
    "category"
  ]
}